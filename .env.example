# ==========================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO VITE
# PROYECTO: GESTIÓN DE RESERVAS DE CAPACITACIONES
# ==========================================

# Modo de funcionamiento de la API
# - 'true': Conectado a un backend PostgreSQL
# - 'false' o vacío: Modo local / offline (usando localStorage del navegador con datos semilla)
VITE_API_MODE=false

# URL base del servidor backend (requerido únicamente si VITE_API_MODE=true)
# Ejemplos:
# - Desarrollo local: http://localhost:5000/api
# - Producción (Coolify): https://reservas-api.tu-dominio.com/api
VITE_API_URL=http://localhost:5000/api
